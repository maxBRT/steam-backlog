# Production Environment Configuration Template
# 
# This file shows recommended production settings.
# In Laravel Cloud, set these as environment variables, not in a file.
# See docs/secrets-management.md for details on each setting.

APP_NAME="Steam Backlog"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-production-domain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# PostgreSQL (provided by Laravel Cloud)
DB_CONNECTION=pgsql
DB_HOST=
DB_PORT=5432
DB_DATABASE=steam_backlog
DB_USERNAME=
DB_PASSWORD=

# Session security settings for production
SESSION_DRIVER=database
SESSION_LIFETIME=10080
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@your-production-domain.com"
MAIL_FROM_NAME="${APP_NAME}"

# Steam API (production key registered with production domain)
STEAM_API_KEY=
STEAM_RETURN_URL="${APP_URL}/auth/steam/callback"
STEAM_REALM="${APP_URL}"

VITE_APP_NAME="${APP_NAME}"
